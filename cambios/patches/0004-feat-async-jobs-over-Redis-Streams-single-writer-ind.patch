+
+
+def test_async_index_returns_202_and_job_completes(client) -> None:
+    response = client.post(
+        "/index", json={"text": _TEXT, "tenant_id": "tenant-a", "mode": "async"}
+    )
+
+    assert response.status_code == 202
+    job_id = response.get_json()["job_id"]

+from tests.integration.inmemory import (
+    HashingEmbeddingModel,
+    InMemoryChunkRepository,
+    InMemoryDocumentRepository,
+    InMemoryVectorIndex,
+    StaticLanguageDetector,
+    StaticTopicClassifier,
+)
+

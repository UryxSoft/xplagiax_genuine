# Copy to .env and adjust. See app/config/app_settings.py and
# app/config/settings.py (ParserSettings) for full field documentation.

# --- Database (ADR-009: PostgreSQL for metadata) ---
DATABASE_URL=postgresql+psycopg://xplagiax:xplagiax@localhost:5432/xplagiax

# --- Parser / GROBID (RF-08, ADR-012) ---
PARSER_GROBID_BASE_URL=http://localhost:8070
PARSER_GROBID_ENABLED=true
PARSER_GROBID_TIMEOUT_SECONDS=30
PARSER_SCANNED_MIN_CHARS_PER_PAGE=200

# --- Embeddings (RF-09, ADR-003) ---
# Perfil "pluma" (NFR-03/04): EMBEDDING_BACKEND=onnx con un modelo pequeno
# exportado (p.ej. multilingual-e5-small int8, ~120 MB residentes, 384 dims)
# en ONNX_MODEL_DIR. El backend sentence-transformers carga
# EMBEDDING_MODEL_NAME via torch (e5-large float32 ~2.2 GB por proceso).
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
ONNX_MODEL_DIR=/models/e5-small-onnx
ONNX_MODEL_FILENAME=model.onnx

# --- Cache L2 de resultados (ADR sect 14) ---
# Sin REDIS_URL: cache LRU en proceso (valido single-node). Con REDIS_URL:
# cache compartida entre workers/nodos con invalidacion por tenant.
#REDIS_URL=redis://localhost:6379/0
SEARCH_CACHE_TTL_SECONDS=300
SEARCH_CACHE_MAX_ENTRIES=1000

# --- Gunicorn (gunicorn.conf.py) ---
WEB_CONCURRENCY=2

# --- TurboVec (ADR-002/007; default 4-bit per docs/RESEARCH.md #1) ---
TURBOVEC_INDEX_PATH=/data/turbovec/index.tvim
TURBOVEC_BIT_WIDTH=4

# --- Fase 3: topologia single-writer (ADR-010) ---
# local: este proceso escribe el indice de forma sincrona (default).
# worker: las replicas web son solo-lectura (hot reload por manifest) y
# toda escritura viaja como job por Redis Streams al worker indexador
# (python -m app.workers.indexer_worker). Requiere REDIS_URL.
INDEX_WRITE_MODE=local
INDEX_DATA_DIR=/data/turbovec
INDEX_CHECKPOINT_EVERY_OPS=50
JOBS_STREAM_KEY=xplagiax:jobs
JOBS_CONSUMER_GROUP=xplagiax-workers
JOBS_CONSUMER_NAME=worker-1
JOB_TTL_SECONDS=604800

# --- Chunking (RF-05) ---
CHUNK_MIN_TOKENS=300
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_RATIO=0.2

# --- Search (ADR-004) ---
TOPIC_CONFIDENCE_THRESHOLD=0.5
SEARCH_TOP_K_PER_SEGMENT=10
